<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="601.0" prefWidth="420" styleClass="root_stack_pane" stylesheets="@css/ticket.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <VBox prefWidth="400" spacing="0" styleClass="main_vbox">

        <!-- Header with event title and description -->
        <VBox alignment="CENTER" prefWidth="400" spacing="8" styleClass="primary_vbox">
            <padding>
                <Insets bottom="22" left="24" right="24" top="28" />
            </padding>
            <Label styleClass="ticket-event-badge" text="EVENT TICKET">
                <font><Font name="System Bold" size="11.0" /></font>
            </Label>
            <Label fx:id="eventName" alignment="CENTER" maxWidth="340" styleClass="ticket-event-title" text="Event Name" wrapText="true">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
        </VBox>

        <!-- Ticket details -->
        <VBox spacing="14" styleClass="ticket-body" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20" left="24" right="24" top="20" />
            </padding>

            <!-- Start and end date side by side -->
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label styleClass="ticket-section-label" text="START DATE AND TIME">
                        <font><Font name="System Bold" size="10.0" /></font>
                    </Label>
                    <Label fx:id="eventStartDate" styleClass="ticket-value-label" text="Jan 1, 2025 18:00">
                        <font><Font size="13.0" /></font>
                    </Label>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label styleClass="ticket-section-label" text="END DATE AND TIME">
                        <font><Font name="System Bold" size="10.0" /></font>
                    </Label>
                    <Label fx:id="eventEndDate" styleClass="ticket-value-label" text="Jan 1, 2025 23:00">
                        <font><Font size="13.0" /></font>
                    </Label>
                </VBox>
            </HBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- Location guidance box -->
            <VBox spacing="8" styleClass="location-box">
            <children>
               <HBox prefHeight="0.0" prefWidth="350.0">
                  <children>
                     <Label text="Location:">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                     <Label fx:id="locationField">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                  </children>
               </HBox>
               <HBox layoutX="11.0" layoutY="11.0" prefHeight="0.0" prefWidth="350.0">
                  <children>
                     <Label text="Venue:">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                     <Label fx:id="venueField">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                  </children>
               </HBox>
               <HBox layoutX="11.0" layoutY="41.0" prefHeight="0.0" prefWidth="350.0">
                  <children>
                     <Label text="Location Guidance:">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                     <Label fx:id="locationGuidanceField">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                  </children>
               </HBox>
               <HBox layoutX="11.0" layoutY="72.0" prefHeight="0.0" prefWidth="350.0">
                  <children>
                     <Label text="Notes:">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                     <Label fx:id="notesField">
                        <HBox.margin>
                           <Insets left="10.0" top="5.0" />
                        </HBox.margin>
                     </Label>
                  </children>
               </HBox>
            </children>
            </VBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- QR code for entry verification -->
            <VBox alignment="CENTER" spacing="10">
                <Label styleClass="ticket-section-label" text="SCAN TO VERIFY">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <StackPane alignment="CENTER" maxHeight="120" maxWidth="120" prefHeight="120" prefWidth="120" styleClass="qr-box">
                    <ImageView fx:id="qrCode" fitHeight="150.0" fitWidth="150.0" preserveRatio="true" />
                    <Label styleClass="qr-placeholder-label" text="QR Code">
                        <font><Font size="12.0" /></font>
                    </Label>
                </StackPane>
            </VBox>

        </VBox>
        <!-- Footer -->
        <HBox alignment="CENTER" prefHeight="40" prefWidth="400" styleClass="bg-top-bar-gradient">
            <Label styleClass="ticket-footer-label" text="Valid for one-time entry only">
                <font><Font name="System Bold" size="11.0" /></font>
            </Label>
        </HBox>

    </VBox>

</StackPane>
