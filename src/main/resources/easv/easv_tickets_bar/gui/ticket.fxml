<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="841.0" prefWidth="420" styleClass="root_stack_pane" stylesheets="@css/ticket.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <VBox prefWidth="400" spacing="0" styleClass="main_vbox">

        <!-- Header with event title and description -->
        <VBox alignment="CENTER" prefWidth="400" spacing="8" styleClass="primary_vbox">
            <padding>
                <Insets bottom="22" left="24" right="24" top="28" />
            </padding>
            <Label styleClass="ticket-event-badge" text="EVENT TICKET">
                <font><Font name="System Bold" size="11.0" /></font>
            </Label>
            <Label fx:id="eventName" alignment="CENTER" maxWidth="340" styleClass="ticket-event-title" text="Event Name" wrapText="true">
                <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <Label fx:id="eventDescription" alignment="CENTER" maxWidth="320" styleClass="ticket-event-description" text="Event description goes here" wrapText="true">
                <font><Font size="12.0" /></font>
            </Label>
            <Region prefHeight="1" prefWidth="60" styleClass="ticket-divider-white" />
        </VBox>

        <!-- Tear line between header and body -->
        <HBox alignment="CENTER" prefHeight="28" prefWidth="400" styleClass="tear-line-box">
            <StackPane prefHeight="28" prefWidth="28" styleClass="tear-line-notch">
                <StackPane.margin><Insets left="-14" /></StackPane.margin>
            </StackPane>
            <Region prefHeight="1" style="-fx-border-color: #d1d5db; -fx-border-width: 0 0 2 0; -fx-border-style: dashed;" HBox.hgrow="ALWAYS" />
            <StackPane prefHeight="28" prefWidth="28" styleClass="tear-line-notch">
                <StackPane.margin><Insets right="-14" /></StackPane.margin>
            </StackPane>
        </HBox>

        <!-- Ticket details -->
        <VBox spacing="14" styleClass="ticket-body" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20" left="24" right="24" top="20" />
            </padding>

            <!-- Attendee name -->
            <VBox spacing="4">
                <Label styleClass="ticket-section-label" text="ATTENDEE">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <Label fx:id="attendeeName" styleClass="ticket-name-label" text="Full Name">
                    <font><Font name="System Bold" size="17.0" /></font>
                </Label>
            </VBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- Email address -->
            <VBox spacing="4">
                <Label styleClass="ticket-section-label" text="EMAIL">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <Label fx:id="attendeeEmail" styleClass="ticket-value-label" text="email@example.com">
                    <font><Font size="13.0" /></font>
                </Label>
            </VBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- Start and end date side by side -->
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label styleClass="ticket-section-label" text="START DATE">
                        <font><Font name="System Bold" size="10.0" /></font>
                    </Label>
                    <Label fx:id="eventStartDate" styleClass="ticket-value-label" text="Jan 1, 2025 18:00">
                        <font><Font size="13.0" /></font>
                    </Label>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label styleClass="ticket-section-label" text="END DATE">
                        <font><Font name="System Bold" size="10.0" /></font>
                    </Label>
                    <Label fx:id="eventEndDate" styleClass="ticket-value-label" text="Jan 1, 2025 23:00">
                        <font><Font size="13.0" /></font>
                    </Label>
                </VBox>
            </HBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- Notes -->
            <VBox spacing="4">
                <Label styleClass="ticket-section-label" text="NOTES">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <Label fx:id="eventNotes" styleClass="ticket-value-label" text="Notes will appear here" wrapText="true">
                    <font><Font size="13.0" /></font>
                </Label>
            </VBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- Location guidance box -->
            <VBox spacing="8">
                <Label styleClass="ticket-section-label" text="LOCATION GUIDANCE">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <VBox spacing="4" styleClass="location-box">
                    <padding>
                        <Insets bottom="12" left="14" right="14" top="12" />
                    </padding>
                    <Label fx:id="locationName" styleClass="location-name-label" text="Venue Name, City">
                        <font><Font name="System Bold" size="13.0" /></font>
                    </Label>
                    <Label fx:id="locationGuidance" styleClass="location-guidance-label" text="Entrance and directions will appear here" wrapText="true">
                        <font><Font size="12.0" /></font>
                    </Label>
                </VBox>
            </VBox>

            <Region prefHeight="1" styleClass="ticket-divider" />

            <!-- QR code for entry verification -->
            <VBox alignment="CENTER" spacing="10">
                <Label styleClass="ticket-section-label" text="SCAN TO VERIFY">
                    <font><Font name="System Bold" size="10.0" /></font>
                </Label>
                <StackPane alignment="CENTER" maxHeight="120" maxWidth="120" prefHeight="120" prefWidth="120" styleClass="qr-box">
                    <ImageView fx:id="qrCode" fitHeight="150.0" fitWidth="150.0" preserveRatio="true" />
                    <Label styleClass="qr-placeholder-label" text="QR Code">
                        <font><Font size="12.0" /></font>
                    </Label>
                </StackPane>
            </VBox>

        </VBox>
        <!-- Footer -->
        <HBox alignment="CENTER" prefHeight="40" prefWidth="400" styleClass="bg-top-bar-gradient">
            <Label styleClass="ticket-footer-label" text="Valid for one-time entry only">
                <font><Font name="System Bold" size="11.0" /></font>
            </Label>
        </HBox>

    </VBox>

</StackPane>
