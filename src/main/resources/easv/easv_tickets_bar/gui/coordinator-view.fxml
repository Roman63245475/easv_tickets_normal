<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="479.0" prefWidth="800.0" stylesheets="@css/coordinator-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="easv.easv_tickets_bar.gui.CoordinatorController">
    <children>
        <VBox fx:id="sideBar" minWidth="0.0" prefHeight="479.0" prefWidth="0.0" styleClass="white-c">
            <children>
                <HBox fx:id="adminHeaderBox" alignment="CENTER" prefHeight="58.0" prefWidth="153.0" spacing="5.0" styleClass="gradient-emerald">
                    <children>
                        <Region id="coordinator-icon" maxHeight="-Infinity" prefHeight="20.0" prefWidth="24.0" styleClass="white-c" />
                        <Label fx:id="adminLabel" styleClass="white-c-text" text="Event Coordinator">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <HBox alignment="CENTER" minWidth="0.0" prefWidth="200.0">
                    <children>
                        <Region id="calendar-icon" maxHeight="-Infinity" prefHeight="20.0" prefWidth="20.0" styleClass="gray-c" />
                        <Button fx:id="menuBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onEventManClick" text="Event Management" HBox.hgrow="ALWAYS" />
                    </children>
                    <VBox.margin>
                        <Insets left="20.0" />
                    </VBox.margin>
                </HBox>
                <HBox alignment="CENTER" layoutX="10.0" layoutY="68.0" minWidth="0.0" prefWidth="200.0">
                    <children>
                        <Region id="ticket-icon" maxHeight="-Infinity" prefHeight="20.0" prefWidth="20.0" styleClass="gray-c" />
                        <Button fx:id="menuBtn1" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onTicketManClick" text="Ticket Management" HBox.hgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets left="20.0" />
                    </padding>
                </HBox>
                <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" prefWidth="200.0" spacing="5.0">
                    <children>
                        <Region id="profile-icon" maxHeight="-Infinity" prefHeight="25.0" prefWidth="25.0" styleClass="gradient-emerald" />
                        <Label minWidth="0.0" text="Welcome, {user}!">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                    <padding>
                        <Insets bottom="20.0" top="20.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
        <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="58" styleClass="gradient-emerald-blue">
                    <children>
                        <Region id="menu-icon" maxHeight="16.0" onMouseClicked="#menuSlide" prefHeight="21.0" prefWidth="21.0" styleClass="white-c">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Region>
                    </children>
                    <padding>
                        <Insets left="20.0" />
                    </padding></HBox>
                <StackPane fx:id="contentBox" prefHeight="479.0" prefWidth="571.0">
                    <children>
                        <VBox fx:id="eventManagementBox" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0">
                            <children>
                                <HBox alignment="CENTER" prefWidth="200.0">
                                    <children>
                                        <Label text="My Events">
                                            <font>
                                                <Font size="28.0" />
                                            </font>
                                        </Label>
                                        <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" text="+ Create Event">
                                            <styleClass>
                                                <String fx:value="gradient-emerald" />
                                                <String fx:value="white-c-text" />
                                            </styleClass>
                                        </Button>
                                    </children>
                                </HBox>
                                <TableView prefHeight="200.0" prefWidth="200.0">
                                    <columns>
                                        <TableColumn prefWidth="75.0" text="ID" />
                                        <TableColumn prefWidth="75.0" text="Event Name" />
                                        <TableColumn prefWidth="75.0" text="Date" />
                                        <TableColumn prefWidth="75.0" text="Location" />
                                        <TableColumn prefWidth="75.0" text="Status" />
                                        <TableColumn prefWidth="75.0" text="Tickets" />
                              <TableColumn prefWidth="75.0" text="Coordinators" />
                              <TableColumn prefWidth="75.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                        <VBox fx:id="ticketManagementBox" alignment="TOP_CENTER" layoutX="30.0" layoutY="30.0" prefHeight="200.0" prefWidth="100.0" spacing="15.0" visible="false">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                                    <children>
                                        <Label styleClass="gradient-indigo-text" text="Ticket Management">
                                            <font>
                                                <Font size="28.0" />
                                            </font>
                                        </Label>
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" text="+ Add Ticket">
                                 <styleClass>
                                    <String fx:value="gradient-indigo" />
                                    <String fx:value="white-c-text" />
                                 </styleClass></Button>
                                    </children>
                                </HBox>
                                <TableView prefHeight="200.0" prefWidth="200.0">
                                    <columns>
                                        <TableColumn prefWidth="75.0" text="ID" />
                                        <TableColumn prefWidth="75.0" text="Event" />
                                        <TableColumn prefWidth="75.0" text="Ticket Type" />
                                        <TableColumn prefWidth="75.0" text="Price" />
                                        <TableColumn prefWidth="75.0" text="Quantity" />
                                        <TableColumn prefWidth="75.0" text="Sold" />
                                        <TableColumn prefWidth="75.0" text="Available" />
                              <TableColumn prefWidth="75.0" text="Status" />
                              <TableColumn prefWidth="75.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </StackPane>
            </children>
        </VBox>
    </children>
</HBox>
