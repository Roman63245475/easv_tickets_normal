<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="479.0" prefWidth="800.0" stylesheets="@css/admin-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="easv.easv_tickets_bar.gui.AdminController">
   <children>
      <VBox fx:id="sideBar" minWidth="0.0" prefHeight="479.0" prefWidth="0.0" styleClass="white-c">
         <children>
            <HBox fx:id="adminHeaderBox" alignment="CENTER" prefHeight="58.0" prefWidth="153.0" spacing="5.0" styleClass="bg-gradient">
               <children>
                  <Region id="shield-icon" maxHeight="24.0" prefHeight="24.0" prefWidth="24.0" styleClass="white-c" />
                  <Label fx:id="adminLabel" prefWidth="96.0" styleClass="white-c-text" text="Admin Panel">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <HBox alignment="CENTER" minWidth="0.0" prefWidth="200.0">
               <children>
                  <Region id="users-icon" maxHeight="-Infinity" prefHeight="15.0" prefWidth="20.0" styleClass="gray-c" />
                  <Button fx:id="menuBtn" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onUserManClick" text="User Management" HBox.hgrow="ALWAYS" />
               </children>
               <VBox.margin>
                  <Insets left="20.0" />
               </VBox.margin>
            </HBox>
            <HBox alignment="CENTER" layoutX="10.0" layoutY="68.0" minWidth="0.0" prefWidth="200.0">
               <children>
                  <Region id="calendar-icon" maxHeight="-Infinity" prefHeight="20.0" prefWidth="20.0" styleClass="gray-c" />
                  <Button fx:id="menuBtn1" maxWidth="Infinity" minWidth="0.0" mnemonicParsing="false" onAction="#onEventManClick" text="Event Management" HBox.hgrow="ALWAYS" />
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding>
            </HBox>
            <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <HBox alignment="CENTER_LEFT" minHeight="58" styleClass="bg-top-bar-gradient">
               <children>
                  <Region id="menu-icon" maxHeight="16.0" onMouseClicked="#menuSlide" prefHeight="21.0" prefWidth="21.0" styleClass="white-c">
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Region>
                  <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" prefWidth="200.0" spacing="5.0">
                     <children>
                        <Label fx:id="welcomeUserLabel" minWidth="0.0" styleClass="white-c-text" text="Welcome, {user}!">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" top="20.0" />
                     </padding>
                  </HBox>
               </children>
               <padding>
                  <Insets left="20.0" />
               </padding></HBox>
            <StackPane fx:id="contentBox" prefHeight="479.0" prefWidth="571.0">
               <children>
                  <VBox fx:id="userManagementBox" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0">
                     <children>
                        <HBox alignment="CENTER" prefWidth="200.0">
                           <children>
                              <Label text="User Management">
                                 <font>
                                    <Font size="28.0" />
                                 </font>
                              </Label>
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#addUser" text="Add User">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                              </Button>
                           </children>
                        </HBox>
                        <TableView fx:id="usersTable" prefHeight="265.0" prefWidth="760.0">
                          <columns>
                            <TableColumn fx:id="userIdColumn" prefWidth="75.0" text="ID" />
                            <TableColumn fx:id="userUsernameColumn" prefWidth="75.0" text="Username" />
                              <TableColumn fx:id="userRoleColumn" prefWidth="75.0" text="Role" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="200.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#editUser" prefHeight="36.0" prefWidth="142.0" text="Edit selected user">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                                 <HBox.margin>
                                    <Insets />
                                 </HBox.margin>
                              </Button>
                              <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#deleteUser" prefHeight="36.0" prefWidth="142.0" text="Delete selected user">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox fx:id="eventManagementBox" alignment="TOP_CENTER" layoutX="30.0" layoutY="30.0" prefHeight="200.0" prefWidth="100.0" spacing="15.0" visible="false">
                     <children>
                        <HBox prefWidth="200.0">
                           <children>
                              <Label text="Event Management">
                                 <font>
                                    <Font size="28.0" />
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <TableView fx:id="eventsTable" prefHeight="265.0" prefWidth="200.0">
                           <columns>
                              <TableColumn fx:id="eventIdColumn" prefWidth="109.0" text="ID" />
                              <TableColumn fx:id="eventNameColumn" prefWidth="134.0" text="Event Name" />
                              <TableColumn fx:id="startDateColumn" prefWidth="126.0" text="Start Date" />
                              <TableColumn fx:id="startTimeColumn" prefWidth="126.0" text="Start Time" />
                              <TableColumn fx:id="endDateColumn" prefWidth="121.0" text="End Date" />
                              <TableColumn fx:id="endTimeColumn" prefWidth="121.0" text="End Time" />
                              <TableColumn fx:id="eventLocationColumn" prefWidth="75.0" text="Location" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER" prefWidth="200.0">
                           <children>
                              <Button minWidth="-Infinity" mnemonicParsing="false" onAction="#assignCoordinator" prefHeight="25.0" prefWidth="150.0" text="Assign a Coordinator">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                              </Button>
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <Button minWidth="-Infinity" mnemonicParsing="false" prefHeight="25.0" prefWidth="146.0" text="Edit selected Event">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                              </Button>
                              <Region prefWidth="200.0" HBox.hgrow="ALWAYS" />
                              <Button fx:id="deleteEventButton" minWidth="-Infinity" mnemonicParsing="false" onAction="#deleteEvent" prefHeight="25.0" prefWidth="156.0" text="Delete selected event">
                                 <styleClass>
                                    <String fx:value="bg-top-bar-gradient" />
                                    <String fx:value="white-c-text" />
                                 </styleClass>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </StackPane>
         </children>
      </VBox>
   </children>
</HBox>
